# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://blhcasesync.com

# ── Anthropic (BLH Bot / YourCase AI) ────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here

# ── Microsoft SharePoint (via Microsoft Graph API) ───────────────────────────
MS_TENANT_ID=your_tenant_id_here
MS_CLIENT_ID=your_client_id_here
MS_CLIENT_SECRET=your_client_secret_here
SHAREPOINT_SITE_URL=https://yourtenant.sharepoint.com/sites/YourSiteName
# Optional: set these to skip runtime discovery (faster cold starts)
SP_SITE_ID=your_sharepoint_site_id_here
SP_DRIVE_ID=your_sharepoint_drive_id_here
SP_CLIENTS_FOLDER_ID=your_sharepoint_clients_folder_id_here

# ── Security ──────────────────────────────────────────────────────────────────
# Required: secret for the /api/check-deadlines cron endpoint
CRON_SECRET=your_random_cron_secret_here
# Required: secret for the /api/webhooks/vercel endpoint
VERCEL_WEBHOOK_SECRET=your_random_webhook_secret_here

# ── Sentry Error Tracking (optional — app works without it) ──────────────────
# Get your DSN from: https://sentry.io → New Project → Next.js
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
SENTRY_ORG=your_sentry_org_slug
SENTRY_PROJECT=casesync
